# ══════════════════════════════════════════════════════════════════
#  VageChain .gitignore
#  Covers: Rust workspace (vage/), docs, scripts, whitepaper
# ══════════════════════════════════════════════════════════════════

# ── Rust build artifacts ───────────────────────────────────────────
/vage/target/
target/
**/*.rs.bk

# ── Runtime databases & state ──────────────────────────────────────
*.redb
*.redb-lock
*.db
*.sqlite
*.sqlite-wal
*.sqlite-shm
explorer.db
/vage/data/
data/

# ── Secrets & private keys — NEVER COMMIT ─────────────────────────
*.pem
*.key
*.p12
*.pfx
*.secret
.env
.env.*
secrets/
private_keys/

# ── LaTeX build artifacts ──────────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# ── Python cache (convert_whitepaper.py) ──────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ── Node / npm (explorer frontend) ────────────────────────────────
node_modules/
dist/
.pnp
.pnp.js

# ── Docker local overrides ────────────────────────────────────────
docker-compose.override.yml

# ── Benchmarks & profiling ────────────────────────────────────────
flamegraph.svg
perf.data
*.profraw
*.profdata

# ── OS artifacts ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# ── IDE artifacts ─────────────────────────────────────────────────
.vscode/settings.json
.vscode/*.log
.idea/
*.iml

# ── Temporary files ───────────────────────────────────────────────
*.tmp
*.bak
*.orig
