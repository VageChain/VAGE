# ══════════════════════════════════════════════════════════════════
#  VageChain .gitattributes
#  Normalize line endings: LF in repo, auto-convert on checkout
# ══════════════════════════════════════════════════════════════════

# Default: detect text files and normalize
* text=auto

# ── Source code → always LF ───────────────────────────────────────
*.rs        text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.tex       text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf

# ── Windows scripts → CRLF ────────────────────────────────────────
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# ── Binary files → never touch line endings ───────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.redb      binary
*.db        binary
*.sqlite    binary
*.zip       binary
*.tar       binary
*.gz        binary
